# Normalise line endings to LF to avoid Windows/macOS/Linux diffs
* text=auto eol=lf

# Explicit LF for shell and Python
*.sh    text eol=lf
*.py    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.json  text eol=lf
*.toml  text eol=lf
*.md    text eol=lf
Dockerfile text eol=lf

# Binary assets
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.xlsx  binary
*.pdf   binary
