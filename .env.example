# LLM-провайдер — любой OpenAI-совместимый endpoint
# Примеры:
#   Ollama:     http://ollama:11434/v1   (по дефолту, без ключа)
#   OpenAI:     https://api.openai.com/v1
#   vLLM:       http://vllm:8000/v1
#   Anthropic:  https://api.anthropic.com/v1  (через litellm-proxy)
LLM_API_BASE_URL=http://ollama:11434/v1
LLM_API_KEY=

# S3 credentials для MinIO
S3_USER=gpthub
S3_PASSWORD=gpthub-secret-key
