# OpenWebUI config — подключается через docker-compose env_file.
# Backend API (наш FastAPI)
OPENAI_API_BASE_URL=http://backend:8000/v1
OPENAI_API_KEY=sk-gpthub-local

# Basic UI
WEBUI_NAME=GPTHub
WEBUI_AUTH=true
ENABLE_SIGNUP=true
DEFAULT_USER_ROLE=user
ENABLE_OLLAMA_API=false
ENABLE_COMMUNITY_SHARING=false
ENABLE_PERSISTENT_CONFIG=false
DEFAULT_MODELS=auto
BYPASS_MODEL_ACCESS_CONTROL=true

# Multi-user (прокидываем user-id заголовок в backend)
ENABLE_FORWARD_USER_INFO_HEADERS=true

# Генерация изображений — проксируем через наш backend
ENABLE_IMAGE_GENERATION=true
IMAGE_GENERATION_ENGINE=openai
IMAGES_OPENAI_API_BASE_URL=http://backend:8000/v1
IMAGES_OPENAI_API_KEY=sk-gpthub-local

# Голос (STT через наш whisper, TTS локально в браузере)
AUDIO_STT_ENGINE=openai
AUDIO_STT_OPENAI_API_BASE_URL=http://backend:8000/v1
AUDIO_STT_OPENAI_API_KEY=sk-gpthub-local
AUDIO_STT_MODEL=whisper-1
AUDIO_TTS_ENGINE=browser_kokoro

# Автогенерация (заголовки чатов, follow-up, автокомплит, теги) через лёгкую модель
TASK_MODEL_EXTERNAL=qwen2.5:7b
ENABLE_FOLLOW_UP_GENERATION=true
ENABLE_AUTOCOMPLETE_GENERATION=true
ENABLE_TITLE_GENERATION=true
ENABLE_TAGS_GENERATION=true

# Расширенные возможности UI
ENABLE_CODE_EXECUTION=true
ENABLE_CODE_INTERPRETER=true
ENABLE_CHANNELS=true
ENABLE_MESSAGE_RATING=true

# Онбординг
WEBUI_BANNERS=[{"id":"welcome","type":"info","title":"GPTHub","content":"Загружай файлы, говори голосом, проси презентацию — модель подберётся сама. Память сохраняется между сессиями.","dismissible":true}]
DEFAULT_PROMPT_SUGGESTIONS=[{"title":["🔍 Deep Research","многошаговое исследование темы"],"content":"Подробно исследуй "},{"title":["📊 Презентация","редактируемый PPTX"],"content":"Сделай презентацию на тему "},{"title":["🌐 Веб-поиск","с трассировкой источников"],"content":"Найди свежие новости про "},{"title":["📄 Анализ файла","RAG по содержимому"],"content":"Что в этом документе?"}]
