{
    "app": {
        "name": "gpthub",
        "host": "0.0.0.0",
        "port": 8000,
        "debug": false
    },
    "api": {
        "llm": {
            "url": "http://localhost:11434/v1",
            "key": "",
            "timeout": 120,
            "default_model": "qwen2.5:7b",
            "vision_model": "qwen2.5vl:7b",
            "code_model": "qwen2.5-coder:7b",
            "reasoning_model": "deepseek-r1:7b",
            "embedding_model": "bge-m3",
            "whisper_model": "whisper-1",
            "image_model": "sdxl"
        },
        "s3": {
            "url": "http://localhost:9000",
            "public_url": "http://localhost:9000",
            "user": "gpthub",
            "password": "gpthub-secret-key",
            "bucket": "presentations",
            "region": "us-east-1"
        }
    },
    "rpc": {
        "memorize_queue": "rpc:memorize"
    },
    "redis": {
        "alias": "gpthub",
        "connection": {
            "host": "localhost",
            "port": 6379,
            "db": 5
        },
        "prefixes": {
            "memory": "mem:",
            "embedding": "emb:",
            "file": "file:",
            "session": "sess:"
        }
    },
    "mongodb": {
        "db": "gpthub",
        "alias": "default",
        "host": "localhost",
        "port": 27017
    },
    "logging": {
        "version": 1,
        "disable_existing_loggers": false,
        "formatters": {
            "default": {
                "format": "[%(asctime)s] %(levelname)s %(name)s: %(message)s",
                "datefmt": "%Y-%m-%d %H:%M:%S"
            }
        },
        "handlers": {
            "console": {
                "class": "logging.StreamHandler",
                "formatter": "default",
                "stream": "ext://sys.stdout"
            }
        },
        "loggers": {
            "api": {"level": "INFO"},
            "control": {"level": "INFO"},
            "rest": {"level": "INFO"}
        },
        "root": {
            "level": "INFO",
            "handlers": ["console"]
        }
    }
}
